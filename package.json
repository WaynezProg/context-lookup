{
  "name": "context-lookup",
  "version": "1.0.0",
  "description": "OpenClaw plugin: function-call style on-demand context lookup tool. Replaces auto-injection with explicit topic queries.",
  "type": "commonjs",
  "main": "./index.js",
  "license": "MIT",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "context",
    "agents",
    "tool"
  ],
  "openclaw": {
    "extensions": ["./index.js"]
  },
  "scripts": {
    "build": "npx esbuild index.ts --bundle --platform=node --format=cjs --outfile=index.js --external:fs --external:path"
  }
}
